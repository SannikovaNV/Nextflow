profiles {

    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor  = 'slurm'
        process.queue     = 'normal'
        process.clusterOptions = '--mail-type=END,FAIL'
    }

    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

}

process {

    withLabel: 'bwa' {
        cpus   = 8
        memory = '16 GB'
        time   = '24h'
        container = 'biocontainers/bwa:v0.7.17'
    }

    withLabel: 'bowtie2' {
        cpus   = 8
        memory = '16 GB'
        time   = '24h'
        container = 'biocontainers/bowtie2:v2.3.5.1'
    }

    withLabel: 'samtools' {
        cpus   = 4
        memory = '8 GB'
        time   = '4h'
        container = 'biocontainers/samtools:v1.9'
    }

    withLabel: 'gatk' {
        cpus   = 4
        memory = '16 GB'
        time   = '48h'
        container = 'broadinstitute/gatk:4.1.4.1'
    }

    withLabel: 'freebayes' {
        cpus   = 4
        memory = '8 GB'
        time   = '24h'
        container = 'biocontainers/freebayes:v1.3.1'
    }

    withLabel: 'varscan' {
        cpus   = 4
        memory = '8 GB'
        time   = '24h'
        container = 'biocontainers/varscan:v2.4.4'
    }

}

manifest {
    name            = 'variant-caller'
    description     = 'Germline variant calling pipeline — BWA/Bowtie2 + GATK/FreeBayes/VarScan'
    version         = '2.0.0'
    nextflowVersion = '>=23.0.0'
}
