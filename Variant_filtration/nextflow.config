// ================================================================
//  nextflow.config  —  Variant Filtration Pipeline
// ================================================================

manifest {
    name        = 'variant-filtration'
    description = 'GATK hard-filter SNPs and INDELs from raw VCF calls'
    version     = '2.0.0'
    nextflowVersion = '>=23.04'
}

// ----------------------------------------------------------------
// Default parameters (override on the command line with --param)
// ----------------------------------------------------------------
params {
    vcf_files        = "results/raw_variant_calling/*.{vcf,vcf.idx}"
    reference        = null
    region_intervals = "NO_FILE"
    outdir           = "results"
    help             = false

    // Resource hints (can be overridden per-profile below)
    max_memory = 32.GB
    max_cpus   = 8
    max_time   = 24.h
}

// ----------------------------------------------------------------
// Process defaults
// ----------------------------------------------------------------
process {
    // Global fallback — keep containers/modules from caching old layers
    shell = ['/bin/bash', '-euo', 'pipefail']

    // All three pipeline processes carry label 'gatk'
    withLabel: 'gatk' {
        cpus   = 4
        memory = 8.GB
        time   = 4.h

        // Uncomment one of the container lines that matches your setup:
        // container = 'broadinstitute/gatk:4.5.0.0'
        // conda     = 'bioconda::gatk4=4.5.0.0'
    }

    // Retry strategy is already set per-process in the script;
    // set the exit-code policy globally here so Nextflow knows
    // which codes are worth retrying vs. which are fatal.
    errorStrategy = { task.exitStatus in [130, 137, 140, 143] ? 'retry' : 'finish' }
    maxRetries    = 2
}

// ----------------------------------------------------------------
// Execution profiles
// ----------------------------------------------------------------
profiles {

    // --- Local workstation -------------------------------------------
    standard {
        process.executor = 'local'

        withLabel: 'gatk' {
            cpus   = 2
            memory = 4.GB
            time   = 2.h
        }
    }

    // --- SLURM cluster -----------------------------------------------
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'

        withLabel: 'gatk' {
            cpus        = 4
            memory      = 16.GB
            time        = 8.h
            clusterOptions = '--account=my_project'   // adjust as needed
        }

        executor {
            queueSize       = 50
            pollInterval    = '30 sec'
            submitRateLimit = '10/1min'
        }
    }

    // --- AWS Batch -------------------------------------------------------
    aws {
        process.executor = 'awsbatch'
        process.queue    = 'nextflow-batch-queue'     // your queue name
        aws.region       = 'us-east-1'

        withLabel: 'gatk' {
            cpus   = 4
            memory = 16.GB
            time   = 8.h
            container = 'broadinstitute/gatk:4.5.0.0'
        }
    }

    // --- Docker (local, reproducibility testing) ----------------------
    docker {
        docker.enabled  = true
        docker.runOptions = '-u $(id -u):$(id -g)'

        withLabel: 'gatk' {
            container = 'broadinstitute/gatk:4.5.0.0'
        }
    }

    // --- Singularity (HPC without Docker) -----------------------------
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true

        withLabel: 'gatk' {
            container = 'docker://broadinstitute/gatk:4.5.0.0'
        }
    }

    // --- Conda (no container daemon) ----------------------------------
    conda {
        conda.enabled = true

        withLabel: 'gatk' {
            conda = 'bioconda::gatk4=4.5.0.0'
        }
    }

    // --- CI / testing (tiny resources, local) -------------------------
    test {
        process.executor = 'local'

        withLabel: 'gatk' {
            cpus   = 1
            memory = 2.GB
            time   = 30.min
        }

        params {
            vcf_files = "test_data/*.{vcf,vcf.idx}"
            reference = "test_data/ref.fa"
            outdir    = "test_results"
        }
    }
}

// ----------------------------------------------------------------
// Work directory & caching
// ----------------------------------------------------------------
workDir = 'work'

// Keep only the last N completed runs in the cache.
// Uncomment to enable automatic cleanup:
// cleanup = true

// ----------------------------------------------------------------
// Reporting & tracing
// ----------------------------------------------------------------
report {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,peak_rss,vmem,submit,start,complete'
}

timeline {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_timeline.html"
    overwrite = true
}

dag {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_dag.svg"
    overwrite = true
}
